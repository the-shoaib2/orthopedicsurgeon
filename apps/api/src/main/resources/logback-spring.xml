<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOGS" value="./logs" />
    <property name="LOG_FILE_NAME" value="orthopedic-api" />

    <!-- 🎨 Premium Console Appender -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>
                %d{HH:mm:ss} %highlight(%-5level) %magenta([%15.15thread]) %cyan(%-30.30logger{29}) : %msg%n
            </Pattern>
        </encoder>
    </appender>

    <!-- 🚀 Console Appender (No Prefix) -->
    <appender name="CleanConsole" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%msg%n</Pattern>
        </encoder>
    </appender>

    <!-- 📂 Professional File Appender -->
    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/${LOG_FILE_NAME}.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</Pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOGS}/archived/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <totalSizeCap>10GB</totalSizeCap>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- 🔇 Silence Noisy Libraries -->
    <logger name="org.hibernate" level="WARN" />
    <logger name="org.springframework" level="WARN" />
    <logger name="org.springframework.web" level="WARN" />
    <logger name="org.springframework.security" level="WARN" />
    <logger name="com.zaxxer.hikari" level="WARN" />
    <logger name="org.flywaydb" level="WARN" />
    <logger name="io.netty" level="WARN" />
    <logger name="org.zalando.logbook" level="ERROR" />

    <!-- 🌐 Profile-specific Root Levels -->
    <springProfile name="dev, local">
        <root level="INFO">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </root>
        <logger name="com.orthopedic.api" level="DEBUG" additivity="false">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </logger>
        <logger name="com.orthopedic.api.auth.security.RequestLoggingFilter" level="INFO" additivity="false">
            <appender-ref ref="CleanConsole" />
        </logger>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </root>
        <logger name="com.orthopedic.api" level="INFO" additivity="false">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </logger>
        <logger name="com.orthopedic.api.auth.security.RequestLoggingFilter" level="INFO" additivity="false">
            <appender-ref ref="CleanConsole" />
        </logger>
    </springProfile>

    <!-- Fallback if no profile is active -->
    <root level="WARN">
        <appender-ref ref="Console" />
        <appender-ref ref="RollingFile" />
    </root>

</configuration>
