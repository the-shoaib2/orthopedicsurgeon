{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*local",
        ".env",
        "tsconfig.json"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "target/**"
            ],
            "inputs": [
                "src/**",
                "public/**",
                "angular.json",
                "tsconfig.json",
                "pom.xml"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "cache": true
        },
        "test": {
            "dependsOn": [
                "^test"
            ],
            "cache": true,
            "inputs": [
                "src/**",
                "*.spec.ts",
                "tsconfig.json",
                "pom.xml"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}